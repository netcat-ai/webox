# Override only when pinning a tag or digest.
# WEBOX_IMAGE=ghcr.io/netcat-ai/webox:main
WEBOX_HTTP_PORT=38080
WEBOX_HTTP_HOST=127.0.0.1
WEBOX_DESKTOP_PORT=6080
WEBOX_DESKTOP_HOST=127.0.0.1
WEBOX_STATE_DIR=./data/state

# Base images and apt mirrors. Defaults use official upstream through Docker's proxy.
RUST_BUILDER_IMAGE=rust:1.96-bookworm
DEBIAN_RUNTIME_IMAGE=debian:bookworm-slim
APT_DEBIAN_MIRROR=
APT_DEBIAN_SECURITY_MIRROR=

# Optional Debian apt mirrors. Keep Docker base images on the official registry.
# APT_DEBIAN_MIRROR=http://mirrors.aliyun.com/debian
# APT_DEBIAN_SECURITY_MIRROR=http://mirrors.aliyun.com/debian-security
